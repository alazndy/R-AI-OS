{
  "name": "raios",
  "publisher": "alazndy",
  "displayName": "R-AI-OS",
  "description": "R-AI-OS Kernel integration for VS Code",
  "version": "0.4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alazndy/r-ai-os"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "raios-sidebar-view",
          "title": "R-AI-OS",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "raios-sidebar-view": [
        {
          "type": "webview",
          "id": "raios.sidebar",
          "name": "R-AI-OS Control Panel"
        }
      ],
      "explorer": [
        {
          "id": "raiosRefactorView",
          "name": "R-AI-OS Refactor",
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "raios.healthCheck",
        "title": "R-AI-OS: Run Health Check"
      },
      {
        "command": "raios.commitPush",
        "title": "R-AI-OS: Commit & Push (Intelligent)"
      },
      {
        "command": "raios.dispatchTask",
        "title": "R-AI-OS: Dispatch Task to Agent..."
      },
      {
        "command": "raios.cortexIndex",
        "title": "R-AI-OS: Re-index Cortex"
      },
      {
        "command": "raios.securityScan",
        "title": "R-AI-OS: Security Scan"
      },
      {
        "command": "raios.licenseCheck",
        "title": "R-AI-OS: License Compliance Check"
      },
      {
        "command": "raios.auditPage",
        "title": "R-AI-OS: Audit Web Page (Lighthouse)..."
      },
      {
        "command": "raios.scanCurrentFile",
        "title": "R-AI-OS: Scan File for Security Issues"
      },
      {
        "command": "raios.openMemory",
        "title": "R-AI-OS: Open Project Memory"
      },
      {
        "command": "raios.showRefactorView",
        "title": "R-AI-OS: Show Refactor Panel"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "raios.securityScan",
          "when": "explorerResourceIsFolder",
          "group": "raios@1"
        },
        {
          "command": "raios.scanCurrentFile",
          "when": "!explorerResourceIsFolder",
          "group": "raios@2"
        }
      ],
      "editor/context": [
        {
          "command": "raios.scanCurrentFile",
          "group": "raios@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "raios.securityScan",
        "key": "ctrl+shift+r s",
        "mac": "cmd+shift+r s"
      },
      {
        "command": "raios.healthCheck",
        "key": "ctrl+shift+r h",
        "mac": "cmd+shift+r h"
      },
      {
        "command": "raios.scanCurrentFile",
        "key": "ctrl+shift+r f",
        "mac": "cmd+shift+r f"
      }
    ],
    "configuration": {
      "title": "R-AI-OS",
      "properties": {
        "raios.httpPort": {
          "type": "number",
          "default": 42071,
          "description": "R-AI-OS HTTP API server port"
        },
        "raios.pathToBinary": {
          "type": "string",
          "default": "raios",
          "description": "Path to the raios executable. Defaults to 'raios' (relying on PATH)."
        },
        "raios.daemonPort": {
          "type": "number",
          "default": 42069,
          "description": "aiosd daemon port"
        },
        "raios.pollInterval": {
          "type": "number",
          "default": 30,
          "description": "Status bar refresh interval (seconds)"
        },
        "raios.diagnosticsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Run security diagnostics automatically on file save"
        },
        "raios.diagnosticsDebounceMs": {
          "type": "number",
          "default": 800,
          "description": "Debounce delay (ms) before triggering a security scan on save"
        },
        "raios.refactor.highLineThreshold": {
          "type": "number",
          "default": 500,
          "description": "Line count at which a file is flagged HIGH for refactor (default: 500)"
        },
        "raios.refactor.mediumLineThreshold": {
          "type": "number",
          "default": 300,
          "description": "Line count at which a file is flagged MEDIUM for refactor (default: 300)"
        },
        "raios.refactor.highUnwrapThreshold": {
          "type": "number",
          "default": 10,
          "description": "Risky-pattern count (unwrap/!!/as any) for HIGH severity (default: 10)"
        },
        "raios.refactor.mediumUnwrapThreshold": {
          "type": "number",
          "default": 5,
          "description": "Risky-pattern count (unwrap/!!/as any) for MEDIUM severity (default: 5)"
        },
        "raios.refactor.highNestingThreshold": {
          "type": "number",
          "default": 10,
          "description": "Max nesting depth (leading spaces ÷ 4) for HIGH severity (default: 10)"
        },
        "raios.refactor.mediumNestingThreshold": {
          "type": "number",
          "default": 8,
          "description": "Max nesting depth for MEDIUM severity (default: 8)"
        },
        "raios.refactor.extensions": {
          "type": "object",
          "default": {},
          "description": "Per-extension threshold overrides. Keys are file extensions (e.g. \"rs\", \"kt\", \"ts\"). Each value can override: highLines, mediumLines, highUnwrap, mediumUnwrap. Example: { \"kt\": { \"highLines\": 800 }, \"rs\": { \"highLines\": 600, \"mediumLines\": 400 } }"
        }
      }
    }
  },
  "scripts": {
    "compile": "npx tsc -p ./",
    "watch": "npx tsc -watch -p ./",
    "package": "vsce package"
  },

  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
