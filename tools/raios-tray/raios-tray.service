[Unit]
Description=R-AI-OS System Tray
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
WorkingDirectory=%h/dev/core/R-AI-OS/tools/raios-tray
ExecStart=%h/dev/tools/raios-tray/.venv/bin/python %h/dev/core/R-AI-OS/tools/raios-tray/raios-tray.py
Restart=on-failure
RestartSec=5
Environment=QT_QPA_PLATFORM=wayland
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
